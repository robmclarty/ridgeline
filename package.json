{
  "name": "ridgeline",
  "version": "0.12.5",
  "description": "Build harness for long-horizon software execution",
  "license": "Apache-2.0",
  "bin": {
    "ridgeline": "dist/cli.js"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "type": "module",
  "scripts": {
    "build": "tsc && rm -rf dist/agents && cp -r src/agents dist/agents && rm -rf dist/plugin && cp -r plugin dist/plugin && cp src/shapes/*.json dist/shapes/",
    "dev": "tsc --watch",
    "check": "node scripts/check.mjs",
    "check:all": "node scripts/check.mjs --all",
    "check:json": "node scripts/check.mjs --json",
    "check:bail": "node scripts/check.mjs --bail",
    "check:mutation": "stryker run",
    "lint": "npm run lint:code && npm run lint:markdown && npm run lint:agents && npm run lint:fallow && npm run lint:struct && npm run lint:spell",
    "lint:code": "oxlint --type-aware --ignore-pattern examples --ignore-pattern .ridgeline",
    "lint:markdown": "markdownlint-cli2 '**/*.md'",
    "lint:agents": "agnix",
    "lint:fallow": "npx fallow",
    "lint:struct": "ast-grep scan",
    "lint:spell": "cspell --no-progress --no-summary",
    "typecheck": "tsc --noEmit --pretty -p tsconfig.check.json",
    "prepublishOnly": "npm run build",
    "coverage": "vitest run --coverage",
    "test": "npm run typecheck && npm run lint && npm run test:unit",
    "test:unit": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:watch": "vitest"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.76",
    "ai": "6.0.176",
    "axe-core": "4.10.3",
    "colorthief": "3.3.1",
    "commander": "13.0.0",
    "fascicle": "0.4.0",
    "maxrects-packer": "2.7.3",
    "sharp": "0.34.5",
    "wcag-contrast": "3.0.0",
    "zod": "4.1.8"
  },
  "peerDependencies": {
    "playwright": ">=1.57.0 <2.0.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ast-grep/cli": "0.42.1",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "@types/node": "22.19.17",
    "@vitest/coverage-v8": "4.1.2",
    "agnix": "0.17.0",
    "cspell": "10.0.0",
    "fallow": "2.13.0",
    "markdownlint-cli2": "0.21.0",
    "oxlint": "1.58.0",
    "oxlint-tsgolint": "0.21.1",
    "typescript": "5.9.3",
    "vitest": "4.1.2"
  }
}
