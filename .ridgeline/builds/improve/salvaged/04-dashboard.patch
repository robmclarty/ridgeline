+import * as fs from "node:fs"
+import * as path from "node:path"
+import * as http from "node:http"
+import { afterEach, beforeEach, describe, expect, it } from "vitest"
+import { makeTempDir, trackTempDir } from "../../../../test/setup"
+import { startDashboard, DashboardHandle, findMostRecentBuild } from "../server"
+
+interface FetchResult {
+  status: number
+  headers: http.IncomingHttpHeaders
+  body: string
+}
+
+const httpGet = (url: string, headers: http.OutgoingHttpHeaders = {}): Promise<FetchResult> =>
+  new Promise((resolve, reject) => {
+    const req = http.get(url, { headers }, (res) => {
+      let body = ""
+      res.setEncoding("utf-8")
+      res.on("data", (chunk) => {
+        body += chunk
+      })
+      res.on("end", () => resolve({ status: res.statusCode ?? 0, headers: res.headers, body }))
+    })
+    req.on("error", reject)
+    req.setTimeout(5000, () => { req.destroy(new Error("timeout")) })
+  })
+
+const fetchStream = (url: string, headers: http.OutgoingHttpHeaders = {}): Promise<{ res: http.IncomingMessage; req: http.ClientRequest }> =>
+  new Promise((resolve, reject) => {
+    const req = http.get(url, { headers }, (res) => {
+      resolve({ res, req })
+    })
+    req.on("error", reject)
+    req.setTimeout(5000, () => { req.destroy(new Error("timeout")) })
+  })
+
+const setupBuild = (cwd: string, name: string): string => {
+  const buildDir = path.join(cwd, ".ridgeline", "builds", name)
+  fs.mkdirSync(path.join(buildDir, "phases"), { recursive: true })
+  fs.writeFileSync(path.join(buildDir, "state.json"), JSON.stringify({
+    buildName: name,
+    startedAt: new Date().toISOString(),
+    pipeline: { shape: "complete", design: "skipped", spec: "complete", research: "skipped", refine: "skipped", plan: "complete", build: "running" },
+    phases: [
+      { id: "01-scaffold", status: "complete", checkpointTag: "", completionTag: "", retries: 0, duration: 1234, completedAt: null, failedAt: null },
+      { id: "02-feature", status: "building", checkpointTag: "", completionTag: null, retries: 0, duration: null, completedAt: null, failedAt: null },
+    ],
+  }))
+  fs.writeFileSync(path.join(buildDir, "budget.json"), JSON.stringify({
+    entries: [],
+    totalCostUsd: 0,
+  }))
+  fs.writeFileSync(path.join(buildDir, "trajectory.jsonl"), "")
+  return buildDir
+}
+
+describe("dashboard server smoke", () => {
+  let handle: DashboardHandle | null = null
+  let cwd: string
+
+  beforeEach(() => {
+    cwd = trackTempDir(makeTempDir())
+  })
+
+  afterEach(async () => {
+    if (handle) {
+      await handle.stop()
+      handle = null
+    }
+  })
+
+  it("GET / returns HTML with Content-Type text/html (criterion 51)", async () => {
+    setupBuild(cwd, "demo")
+    handle = await startDashboard({ cwd, buildName: "demo", port: 0 })
+    const res = await httpGet(`${handle.url}`)
+    expect(res.status).toBe(200)
+    expect(String(res.headers["content-type"])).toContain("text/html")
+    expect(res.body).toContain("<title>● ridgeline")
+    expect(res.body).toContain("ridgeline")
+    expect(res.body).toContain("#0B0F14")
+  })
+
+  it("GET /state returns JSON snapshot for polling fallback (criterion 7, 51)", async () => {
+    setupBuild(cwd, "demo")
+    handle = await startDashboard({ cwd, buildName: "demo", port: 0 })
+    const res = await httpGet(`${handle.url}state`)
+    expect(res.status).toBe(200)
+    expect(String(res.headers["content-type"])).toContain("application/json")
+    const parsed = JSON.parse(res.body)
+    expect(parsed).toHaveProperty("state")
+    expect(parsed).toHaveProperty("budget")
+  })
+
+  it("GET /events responds with SSE headers (criterion 8, 51)", async () => {
+    setupBuild(cwd, "demo")
+    handle = await startDashboard({ cwd, buildName: "demo", port: 0 })
+    const { res, req } = await fetchStream(`${handle.url}events`)
+    expect(res.statusCode).toBe(200)
+    expect(String(res.headers["content-type"])).toBe("text/event-stream")
+    expect(String(res.headers["cache-control"])).toContain("no-cache")
+    expect(String(res.headers["connection"])).toBe("keep-alive")
+    expect(String(res.headers["x-accel-buffering"])).toBe("no")
+    req.destroy()
+  })
+
+  it("GET / returns 404 for unknown paths (criterion 9)", async () => {
+    setupBuild(cwd, "demo")
+    handle = await startDashboard({ cwd, buildName: "demo", port: 0 })
+    const res = await httpGet(`${handle.url}unknown`)
+    expect(res.status).toBe(404)
+  })
+
+  it("binds to 127.0.0.1 only (criterion 1)", async () => {
+    setupBuild(cwd, "demo")
+    handle = await startDashboard({ cwd, buildName: "demo", port: 0 })
+    const addr = handle.server.address()
+    if (addr && typeof addr === "object") {
+      expect(addr.address).toBe("127.0.0.1")
+    }
+  })
+
+  it("finds the most recently modified build when no name supplied (criterion 3)", () => {
+    const aDir = setupBuild(cwd, "a")
+    const bDir = setupBuild(cwd, "b")
+    const now = Date.now()
+    fs.utimesSync(aDir, new Date(now - 5000), new Date(now - 5000))
+    fs.utimesSync(bDir, new Date(now), new Date(now))
+    expect(findMostRecentBuild(cwd)).toBe("b")
+  })
+
+  it("falls back to the next free port when the requested port is busy (criterion 1)", async () => {
+    setupBuild(cwd, "demo")
+    const blocker = http.createServer(() => {})
+    await new Promise<void>((resolve) => blocker.listen(0, "127.0.0.1", () => resolve()))
+    const addr = blocker.address()
+    if (!addr || typeof addr !== "object") throw new Error("listener address missing")
+    const blocked = addr.port
+    try {
+      handle = await startDashboard({ cwd, buildName: "demo", port: blocked })
+      expect(handle.port).not.toBe(blocked)
+    } finally {
+      blocker.close()
+    }
+  })
+
+  it("emits retry: 2000 and replays the initial snapshot on first connect (criterion 12)", async () => {
+    setupBuild(cwd, "demo")
+    handle = await startDashboard({ cwd, buildName: "demo", port: 0 })
+    const received = await new Promise<string>((resolve, reject) => {
+      const req = http.get(`${handle!.url}events`, (res) => {
+        let buf = ""
+        res.setEncoding("utf-8")
+        res.on("data", (chunk) => {
+          buf += chunk
+          if (buf.length > 512) {
+            req.destroy()
+            resolve(buf)
+          }
+        })
+        res.on("error", reject)
+      })
+      req.on("error", (e) => {
+        if ((e as NodeJS.ErrnoException).code === "ECONNRESET") resolve("")
+        else reject(e)
+      })
+      setTimeout(() => { req.destroy(); resolve("") }, 2000)
+    })
+    expect(received).toContain("retry: 2000")
+  })
+})
