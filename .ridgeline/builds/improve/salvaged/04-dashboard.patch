+import { describe, expect, it } from "vitest"
+import * as wcag from "wcag-contrast"
+import { renderCss, bakeTokens } from "../css"
+import { compositeOver } from "../../contrast"
+
+const css = renderCss()
+const PALETTE = {
+  bg: "#0B0F14",
+  panel: "#121821",
+  border: "#1F2937",
+  text: "#E5E7EB",
+  textDim: "#9CA3AF",
+  error: "#EF4444",
+  success: "#10B981",
+  warning: "#F59E0B",
+  info: "#06B6D4",
+}
+
+describe("dashboard css", () => {
+  it("declares every design token on :root with exact hex values", () => {
+    expect(css).toMatch(/--bg:\s*#0B0F14/)
+    expect(css).toMatch(/--panel:\s*#121821/)
+    expect(css).toMatch(/--border:\s*#1F2937/)
+    expect(css).toMatch(/--text:\s*#E5E7EB/)
+    expect(css).toMatch(/--text-dim:\s*#9CA3AF/)
+    expect(css).toMatch(/--error:\s*#EF4444/)
+    expect(css).toMatch(/--success:\s*#10B981/)
+    expect(css).toMatch(/--warning:\s*#F59E0B/)
+    expect(css).toMatch(/--info:\s*#06B6D4/)
+  })
+
+  it("contains no gradients", () => {
+    expect(css).not.toMatch(/linear-gradient|radial-gradient|conic-gradient/i)
+  })
+
+  it("never uses pure #000", () => {
+    expect(css).not.toMatch(/#000\b/)
+    expect(css).not.toMatch(/#000000/)
+  })
+
+  it("declares no drop shadows", () => {
+    expect(css).not.toMatch(/box-shadow\s*:\s*(?!none)/)
+  })
+
+  it("has no @font-face declarations", () => {
+    expect(css).not.toMatch(/@font-face/)
+  })
+
+  it("uses the required sans stack", () => {
+    expect(css).toContain("-apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif")
+  })
+
+  it("uses the required mono stack", () => {
+    expect(css).toContain("ui-monospace, 'SF Mono', Menlo, Consolas, monospace")
+  })
+
+  it("restricts rendered font sizes to the allowed scale {11, 12, 13, 14, 16, 20}", () => {
+    const allowed = new Set(["11", "12", "13", "14", "16", "20"])
+    const matches = css.match(/font-size:\s*(\d+)px/g) ?? []
+    for (const m of matches) {
+      const n = m.match(/(\d+)/)?.[1]
+      expect(allowed.has(n ?? ""), `disallowed font-size in css: ${m}`).toBe(true)
+    }
+  })
+
+  it("defines exactly three @keyframes animations", () => {
+    const keyframes = css.match(/@keyframes\s+[\w-]+/g) ?? []
+    expect(keyframes.length).toBe(3)
+    const names = keyframes.map((k) => k.replace(/@keyframes\s+/, ""))
+    expect(new Set(names).size).toBe(3)
+    expect(names).toContain("pill-pulse")
+    expect(names).toContain("row-flash")
+    expect(names).toContain("banner-fade")
+  })
+
+  it("has no transform translate/scale/rotate animations", () => {
+    const keyframesBlock = (css.match(/@keyframes[^}]+\{[^]*?\}\s*\}/g) ?? []).join("\n")
+    expect(keyframesBlock).not.toMatch(/translate|scale\(|rotate/)
+  })
+
+  it("references hex values only inside :root", () => {
+    const rootMatch = css.match(/:root\s*\{[^]*?\}/)
+    expect(rootMatch).toBeTruthy()
+    const rootBlock = rootMatch![0]
+    const bodyOutsideRoot = css.replace(rootBlock, "")
+    const hexMatches = bodyOutsideRoot.match(/#[0-9A-Fa-f]{3,8}\b/g) ?? []
+    expect(hexMatches, `hex values found outside :root: ${hexMatches.join(", ")}`).toEqual([])
+  })
+
+  it("has a prefers-reduced-motion block that disables the running pulse", () => {
+    const rmMatch = css.match(/@media \(prefers-reduced-motion: reduce\)\s*\{[^]*?\}\s*\}/)
+    expect(rmMatch).toBeTruthy()
+    const block = rmMatch![0]
+    expect(block).toMatch(/\.pill-running\s*\{[^}]*animation:\s*none/)
+    expect(block).toMatch(/\.pill-running\s*\{[^}]*outline:\s*2px\s+solid\s+var\(--info\)/)
+  })
+
+  it("uses a 1.5s ease-in-out opacity pulse for the running pill", () => {
+    expect(css).toMatch(/animation:\s*pill-pulse\s+1500ms\s+ease-in-out\s+infinite/)
+    expect(css).toMatch(/@keyframes pill-pulse\s*\{[^}]*opacity:\s*0\.6/)
+    expect(css).toMatch(/@keyframes pill-pulse[^}]*opacity:\s*1/)
+  })
+
+  it("uses a 300ms row flash", () => {
+    expect(css).toMatch(/animation:\s*row-flash\s+300ms/)
+  })
+
+  it("uses a 400ms banner fade", () => {
+    expect(css).toMatch(/animation:\s*banner-fade\s+400ms/)
+  })
+})
+
+describe("baked contrast tokens", () => {
+  const t = bakeTokens()
+
+  const pairs: Array<{ label: string; text: string; accent: string }> = [
+    { label: "info", text: t.infoText, accent: PALETTE.info },
+    { label: "success", text: t.successText, accent: PALETTE.success },
+    { label: "warning", text: t.warningText, accent: PALETTE.warning },
+    { label: "error", text: t.errorText, accent: PALETTE.error },
+  ]
+
+  for (const { label, text, accent } of pairs) {
+    it(`${label} text on its composited 10%-opacity fill achieves ≥4.5:1`, () => {
+      const effectiveFill = compositeOver(accent, PALETTE.bg, 0.1)
+      const ratio = wcag.hex(text, effectiveFill)
+      expect(ratio).toBeGreaterThanOrEqual(4.5)
+    })
+  }
+
+  it("baseline text on bg clears 16:1", () => {
+    expect(wcag.hex(PALETTE.text, PALETTE.bg)).toBeGreaterThanOrEqual(16)
+  })
+
+  it("text-dim on bg clears 7.5:1", () => {
+    expect(wcag.hex(PALETTE.textDim, PALETTE.bg)).toBeGreaterThanOrEqual(7.5)
+  })
+})
