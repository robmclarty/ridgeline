index 0000000..1bc9260
--- /dev/null
+++ b/src/ui/dashboard/html.ts
@@ -0,0 +1,341 @@
+import { renderCss } from "./css"
+
+const STATUS_COLOR: Record<string, string> = {
+  running: "#06B6D4",
+  complete: "#10B981",
+  failed: "#EF4444",
+  pending: "#9CA3AF",
+}
+
+export const faviconDataUri = (status: string): string => {
+  const color = STATUS_COLOR[status] ?? STATUS_COLOR.pending
+  const svg = `<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'><circle cx='8' cy='8' r='7' fill='${color}'/></svg>`
+  return `data:image/svg+xml,${encodeURIComponent(svg)}`
+}
+
+const escapeHtml = (s: string): string =>
+  s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;")
+
+export interface BuildSnapshot {
+  buildName: string | null
+  status: string
+  port: number
+}
+
+export const renderTitle = (buildName: string | null, status: string): string => {
+  if (!buildName) return "● ridgeline"
+  return `● ridgeline · ${buildName} · ${status}`
+}
+
+export const renderHtml = (snapshot: BuildSnapshot): string => {
+  const title = renderTitle(snapshot.buildName, snapshot.status)
+  const favicon = faviconDataUri(snapshot.status)
+  const css = renderCss()
+  const url = `http://127.0.0.1:${snapshot.port}/`
+
+  const body = snapshot.buildName
+    ? `<div class="main" id="main">
+    <header class="header">
+      <div class="wordmark">ridgeline</div>
+      <div class="build-name" id="build-name">${escapeHtml(snapshot.buildName)}</div>
+      <div class="elapsed" id="elapsed"></div>
+      <div class="status-pill" id="status-pill"><span class="pill pill-pending" id="status-pill-inner">${escapeHtml(snapshot.status.toUpperCase())}</span></div>
+    </header>
+    <section class="cost-meter panel" aria-label="Cost">
+      <div class="cost-total" id="cost-total">$0.00</div>
+      <div class="cost-breakdown" id="cost-breakdown"></div>
+    </section>
+    <section class="phase-list" id="phase-list" aria-label="Phases"></section>
+  </div>`
+    : `<div class="main" id="main">
+    <header class="header">
+      <div class="wordmark">ridgeline</div>
+    </header>
+    <div class="empty" id="empty">
+      No build attached. Run ridgeline &lt;name&gt; "intent" in another terminal, then reload.
+      <span class="empty-url">${escapeHtml(url)}</span>
+    </div>
+  </div>`
+
+  return `<!doctype html>
+<html lang="en">
+<head>
+<meta charset="utf-8">
+<meta name="viewport" content="width=device-width, initial-scale=1">
+<title>${escapeHtml(title)}</title>
+<link id="favicon" rel="icon" type="image/svg+xml" href="${favicon}">
+<style>${css}</style>
+</head>
+<body>
+<div id="disconnect-banner" class="disconnect-banner hidden" role="status">
+  <span class="disconnect-dot" aria-hidden="true"></span>
+  <span>Disconnected from ridgeline process. Retrying…</span>
+</div>
+${body}
+<script>${renderClientJs(snapshot.port)}</script>
+</body>
+</html>
+`
+}
+
+const renderClientJs = (port: number): string => {
+  const source = CLIENT_JS_SOURCE
+  return source.replace(/__DASHBOARD_PORT__/g, String(port))
+}
+
+const CLIENT_JS_SOURCE = `(function(){
+  var state = null;
+  var budget = null;
+  var lastEventId = 0;
+  var es = null;
+  var pollTimer = null;
+  var lastFaviconColor = null;
+  var lastStatus = null;
+  var STATUS_COLOR = { running: '#06B6D4', complete: '#10B981', failed: '#EF4444', pending: '#9CA3AF' };
+
+  function qs(id){ return document.getElementById(id); }
+
+  function fmtMs(ms){
+    if (ms == null || isNaN(ms)) return '';
+    var s = Math.floor(ms / 1000);
+    var h = Math.floor(s / 3600);
+    var m = Math.floor((s % 3600) / 60);
+    var sec = s % 60;
+    if (h > 0) return h + 'h ' + (m < 10 ? '0' : '') + m + 'm';
+    if (m > 0) return m + 'm ' + (sec < 10 ? '0' : '') + sec + 's';
+    return sec + 's';
+  }
+
+  function fmtUsd(n){
+    if (n == null || isNaN(n)) return '$0.00';
+    return '$' + Number(n).toFixed(2);
+  }
+
+  function setFavicon(status){
+    var color = STATUS_COLOR[status] || STATUS_COLOR.pending;
+    if (color === lastFaviconColor) return;
+    lastFaviconColor = color;
+    var svg = "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'><circle cx='8' cy='8' r='7' fill='" + color + "'/></svg>";
+    var link = qs('favicon');
+    if (link) link.setAttribute('href', 'data:image/svg+xml,' + encodeURIComponent(svg));
+  }
+
+  function setTitle(){
+    var name = state && state.buildName ? state.buildName : '';
+    var status = (state && statusLabel(state)) || 'pending';
+    var parts = ['● ridgeline'];
+    if (name) parts.push(name);
+    if (name) parts.push(status);
+    document.title = parts.join(' · ');
+  }
+
+  function statusLabel(s){
+    if (!s) return 'pending';
+    if (s.pipeline && s.pipeline.build) {
+      if (s.pipeline.build === 'running') return 'running';
+      if (s.pipeline.build === 'complete') return 'done';
+    }
+    if (s.phases && s.phases.some(function(p){ return p.status === 'failed'; })) return 'failed';
+    if (s.phases && s.phases.some(function(p){ return p.status === 'building' || p.status === 'reviewing'; })) return 'running';
+    if (s.phases && s.phases.length > 0 && s.phases.every(function(p){ return p.status === 'complete'; })) return 'done';
+    return 'pending';
+  }
+
+  function phaseStatusClass(s){
+    switch (s) {
+      case 'building':
+      case 'reviewing': return 'pill-running';
+      case 'complete': return 'pill-done';
+      case 'failed': return 'pill-failed';
+      case 'skipped': return 'pill-skipped';
+      default: return 'pill-pending';
+    }
+  }
+
+  function phaseStatusLabel(s){
+    switch (s) {
+      case 'building':
+      case 'reviewing': return 'RUNNING';
+      default: return String(s || 'pending').toUpperCase();
+    }
+  }
+
+  function statusKey(s){
+    switch (s) {
+      case 'complete': return 'complete';
+      case 'failed': return 'failed';
+      case 'running':
+      case 'building':
+      case 'reviewing': return 'running';
+      default: return 'pending';
+    }
+  }
+
+  function renderStatusPill(){
+    var pill = qs('status-pill-inner');
+    if (!pill || !state) return;
+    var label = statusLabel(state);
+    pill.className = 'pill ' + phaseStatusClass(label === 'done' ? 'complete' : (label === 'running' ? 'building' : label));
+    pill.textContent = label.toUpperCase();
+  }
+
+  function renderElapsed(){
+    var el = qs('elapsed');
+    if (!el || !state) return;
+    var started = state.startedAt ? new Date(state.startedAt).getTime() : null;
+    if (!started) { el.textContent = ''; return; }
+    var ms = Date.now() - started;
+    el.textContent = fmtMs(ms);
+  }
+
+  function renderPhases(){
+    var list = qs('phase-list');
+    if (!list || !state || !state.phases) return;
+    var overall = statusLabel(state);
+    var fragments = [];
+    for (var i = 0; i < state.phases.length; i++) {
+      var p = state.phases[i];
+      var cls = 'phase-row';
+      if (p.status === 'failed') cls += ' phase-failed';
+      fragments.push('<div class="' + cls + '" data-phase-id="' + escHtml(p.id) + '">' +
+        '<span class="phase-id">' + escHtml(p.id) + '</span>' +
+        '<span class="phase-slug">' + escHtml(p.slug || p.id) + '</span>' +
+        '<span class="phase-elapsed">' + escHtml(fmtMs(p.duration)) + '</span>' +
+        '<span class="pill ' + phaseStatusClass(p.status) + '">' + escHtml(phaseStatusLabel(p.status)) + '</span>' +
+      '</div>');
+      if (p.status === 'failed' && state.lastError) {
+        fragments.push('<div class="phase-error">' + escHtml(state.lastError) + '</div>');
+      }
+    }
+    list.innerHTML = fragments.join('');
+    void overall;
+  }
+
+  function renderCost(){
+    var totalEl = qs('cost-total');
+    if (totalEl && budget) totalEl.textContent = fmtUsd(budget.totalCostUsd);
+    var brk = qs('cost-breakdown');
+    if (!brk || !budget) return;
+    var stages = ['spec', 'plan', 'research', 'build', 'review'];
+    var totals = { spec: 0, plan: 0, research: 0, build: 0, review: 0 };
+    (budget.entries || []).forEach(function(e){
+      var key = e.phase;
+      if (e.role === 'reviewer') key = 'review';
+      else if (e.role === 'researcher' || e.role === 'refiner') key = 'research';
+      else if (e.role === 'planner') key = 'plan';
+      else if (e.role === 'specialist' || e.role === 'synthesizer') key = key === 'research' ? 'research' : 'spec';
+      else if (e.role === 'builder') key = 'build';
+      if (totals[key] == null) key = 'spec';
+      totals[key] += e.costUsd || 0;
+    });
+    var out = [];
+    for (var i = 0; i < stages.length; i++) {
+      out.push('<div class="cost-label">' + stages[i] + '</div>');
+    }
+    for (var j = 0; j < stages.length; j++) {
+      out.push('<div>' + fmtUsd(totals[stages[j]]) + '</div>');
+    }
+    brk.innerHTML = out.join('');
+  }
+
+  function escHtml(s){
+    return String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
+  }
+
+  function flashRow(phaseId){
+    var row = document.querySelector('[data-phase-id="' + phaseId + '"]');
+    if (!row) return;
+    row.classList.remove('row-flash');
+    void row.offsetWidth;
+    row.classList.add('row-flash');
+  }
+
+  function onState(data){
+    var next = JSON.parse(data);
+    var prevPhases = state && state.phases ? state.phases : [];
+    state = next;
+    setTitle();
+    setFavicon(statusKey(statusLabel(state)));
+    renderStatusPill();
+    renderPhases();
+    renderElapsed();
+    if (prevPhases.length && state.phases) {
+      for (var i = 0; i < state.phases.length; i++) {
+        var p = state.phases[i];
+        var prior = prevPhases.find ? prevPhases.find(function(q){ return q.id === p.id; }) : null;
+        if (prior && prior.status !== p.status) flashRow(p.id);
+      }
+    }
+  }
+
+  function onBudget(data){
+    budget = JSON.parse(data);
+    renderCost();
+  }
+
+  function onTrajectory(data){
+    try {
+      var entry = JSON.parse(data);
+      if (entry && entry.type && entry.type.indexOf('fail') !== -1 && state) {
+        state.lastError = entry.summary || state.lastError;
+        renderPhases();
+      }
+    } catch (_) { /* tolerate unknown shapes */ }
+  }
+
+  function showDisconnect(){
+    var b = qs('disconnect-banner');
+    if (!b) return;
+    b.classList.remove('hidden', 'fading');
+  }
+
+  function hideDisconnect(){
+    var b = qs('disconnect-banner');
+    if (!b) return;
+    if (b.classList.contains('hidden')) return;
+    b.classList.add('fading');
+    setTimeout(function(){ b.classList.add('hidden'); b.classList.remove('fading'); }, 400);
+  }
+
+  function startPolling(){
+    if (pollTimer) return;
+    pollTimer = setInterval(function(){
+      fetch('/state').then(function(r){ return r.json(); }).then(function(snap){
+        if (snap && snap.state) onState(JSON.stringify(snap.state));
+        if (snap && snap.budget) onBudget(JSON.stringify(snap.budget));
+      }).catch(function(){ /* keep polling */ });
+    }, 2000);
+  }
+
+  function stopPolling(){
+    if (pollTimer) { clearInterval(pollTimer); pollTimer = null; }
+  }
+
+  function connect(){
+    if (typeof EventSource === 'undefined') { startPolling(); return; }
+    try {
+      es = new EventSource('/events');
+    } catch (_) { startPolling(); return; }
+    es.addEventListener('state', function(ev){ lastEventId = Number(ev.lastEventId) || lastEventId; onState(ev.data); hideDisconnect(); stopPolling(); });
+    es.addEventListener('budget', function(ev){ lastEventId = Number(ev.lastEventId) || lastEventId; onBudget(ev.data); hideDisconnect(); stopPolling(); });
+    es.addEventListener('trajectory', function(ev){ lastEventId = Number(ev.lastEventId) || lastEventId; onTrajectory(ev.data); hideDisconnect(); stopPolling(); });
+    es.onopen = function(){ hideDisconnect(); stopPolling(); };
+    es.onerror = function(){ showDisconnect(); startPolling(); };
+  }
+
+  function init(){
+    fetch('/state').then(function(r){ return r.json(); }).then(function(snap){
+      if (snap && snap.state) onState(JSON.stringify(snap.state));
+      if (snap && snap.budget) onBudget(JSON.stringify(snap.budget));
+    }).catch(function(){}).finally(function(){
+      connect();
+      setInterval(renderElapsed, 1000);
+    });
+  }
+
+  if (document.readyState === 'loading') {
+    document.addEventListener('DOMContentLoaded', init);
+  } else {
+    init();
+  }
+})();`
