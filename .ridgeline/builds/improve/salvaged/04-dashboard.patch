new file mode 100644
index 0000000..8f00218
--- /dev/null
+++ b/src/ui/dashboard/__tests__/watch.test.ts
@@ -0,0 +1,109 @@
+import * as fs from "node:fs"
+import * as path from "node:path"
+import { afterEach, beforeEach, describe, expect, it } from "vitest"
+import { makeTempDir, trackTempDir } from "../../../../test/setup"
+import { watchAppendOnlyFile, watchJsonFile } from "../watch"
+
+const sleep = (ms: number): Promise<void> => new Promise((r) => setTimeout(r, ms))
+
+describe("watchAppendOnlyFile", () => {
+  let cwd: string
+  beforeEach(() => { cwd = trackTempDir(makeTempDir()) })
+
+  it("emits exactly one event per appended line and tracks byte offsets (criterion 16, 57)", async () => {
+    const fp = path.join(cwd, "trajectory.jsonl")
+    fs.writeFileSync(fp, `{"timestamp":"t","type":"existing","summary":"old"}\n`)
+
+    const lines: string[] = []
+    const watcher = watchAppendOnlyFile(fp, (line) => { lines.push(line) }, { debounceMs: 20 })
+
+    try {
+      const offsetBefore = watcher.getOffset()
+      expect(offsetBefore).toBeGreaterThan(0)
+
+      fs.appendFileSync(fp, `{"timestamp":"t","type":"phase_advance","summary":"new"}\n`)
+      await sleep(200)
+
+      expect(lines).toHaveLength(1)
+      expect(lines[0]).toContain("phase_advance")
+      expect(watcher.getOffset()).toBeGreaterThan(offsetBefore)
+    } finally {
+      watcher.close()
+    }
+  })
+
+  it("never reads prior lines from the file on a subsequent append", async () => {
+    const fp = path.join(cwd, "trajectory.jsonl")
+    fs.writeFileSync(fp, "")
+    const lines: string[] = []
+    const watcher = watchAppendOnlyFile(fp, (line) => { lines.push(line) }, { debounceMs: 20 })
+
+    try {
+      fs.appendFileSync(fp, "line-a\n")
+      await sleep(200)
+      fs.appendFileSync(fp, "line-b\n")
+      await sleep(200)
+      expect(lines).toEqual(["line-a", "line-b"])
+    } finally {
+      watcher.close()
+    }
+  })
+})
+
+describe("watchJsonFile", () => {
+  let cwd: string
+  beforeEach(() => { cwd = trackTempDir(makeTempDir()) })
+
+  it("debounces rapid changes and only dispatches when content actually changes (criterion 15)", async () => {
+    const fp = path.join(cwd, "state.json")
+    fs.writeFileSync(fp, JSON.stringify({ v: 1 }))
+
+    const emits: unknown[] = []
+    const watcher = watchJsonFile<unknown>(fp, (v) => { emits.push(v) }, { debounceMs: 30 })
+
+    try {
+      // same content rewritten — should not emit
+      fs.writeFileSync(fp, JSON.stringify({ v: 1 }))
+      await sleep(100)
+      expect(emits).toEqual([])
+
+      // changed content — should emit
+      fs.writeFileSync(fp, JSON.stringify({ v: 2 }))
+      await sleep(150)
+      expect(emits).toHaveLength(1)
+    } finally {
+      watcher.close()
+    }
+  })
+})
+
+const walkTs = (root: string): string[] => {
+  const out: string[] = []
+  const walk = (dir: string): void => {
+    for (const entry of fs.readdirSync(dir, { withFileTypes: true })) {
+      const fp = path.join(dir, entry.name)
+      if (entry.isDirectory()) {
+        if (entry.name === "__tests__") continue
+        walk(fp)
+      } else if (entry.isFile() && fp.endsWith(".ts")) {
+        out.push(fp)
+      }
+    }
+  }
+  walk(root)
+  return out
+}
+
+describe("no fs.watchFile polling (criterion 17)", () => {
+  it("dashboard source never calls fs.watchFile", () => {
+    const files = [
+      ...walkTs(path.resolve(__dirname, "..")),
+      path.resolve(__dirname, "../../../commands/ui.ts"),
+    ]
+    for (const f of files) {
+      if (!fs.existsSync(f)) continue
+      const src = fs.readFileSync(f, "utf-8")
+      expect(src.includes("watchFile"), `fs.watchFile found in ${f}`).toBe(false)
+    }
+  })
+})
diff --git a/src/ui/dashboard/css.ts b/src/ui/dashboard/css.ts
new file mode 100644
index 0000000..46c08fd
--- /dev/null
+++ b/src/ui/dashboard/css.ts
@@ -0,0 +1,314 @@
+import { brightenForContrast, compositeOver } from "../contrast"
+
+const BG = "#0B0F14"
+const ACCENTS = {
+  error: "#EF4444",
+  success: "#10B981",
+  warning: "#F59E0B",
+  info: "#06B6D4",
+} as const
+
+const toHexAlpha = (hex: string, alphaPct: number): string => {
+  const a = Math.round((alphaPct / 100) * 255)
+  const hh = a.toString(16).padStart(2, "0").toUpperCase()
+  return `${hex}${hh}`
+}
+
+export interface BakedTokens {
+  errorText: string
+  successText: string
+  warningText: string
+  infoText: string
+  errorFill: string
+  successFill: string
+  warningFill: string
+  infoFill: string
+  infoFlash: string
+}
+
+export const bakeTokens = (): BakedTokens => ({
+  errorText: brightenForContrast(ACCENTS.error, compositeOver(ACCENTS.error, BG, 0.1)),
+  successText: brightenForContrast(ACCENTS.success, compositeOver(ACCENTS.success, BG, 0.1)),
+  warningText: brightenForContrast(ACCENTS.warning, compositeOver(ACCENTS.warning, BG, 0.1)),
+  infoText: brightenForContrast(ACCENTS.info, compositeOver(ACCENTS.info, BG, 0.1)),
+  errorFill: toHexAlpha(ACCENTS.error, 10),
+  successFill: toHexAlpha(ACCENTS.success, 10),
+  warningFill: toHexAlpha(ACCENTS.warning, 10),
+  infoFill: toHexAlpha(ACCENTS.info, 10),
+  infoFlash: toHexAlpha(ACCENTS.info, 15),
+})
+
+export const renderCss = (): string => {
+  const t = bakeTokens()
+  return `:root {
+  --bg: ${BG};
+  --panel: #121821;
+  --border: #1F2937;
+  --text: #E5E7EB;
+  --text-dim: #9CA3AF;
+  --error: ${ACCENTS.error};
+  --success: ${ACCENTS.success};
+  --warning: ${ACCENTS.warning};
+  --info: ${ACCENTS.info};
+  --error-fill: ${t.errorFill};
+  --success-fill: ${t.successFill};
+  --warning-fill: ${t.warningFill};
+  --info-fill: ${t.infoFill};
+  --info-flash: ${t.infoFlash};
+  --error-text: ${t.errorText};
+  --success-text: ${t.successText};
+  --warning-text: ${t.warningText};
+  --info-text: ${t.infoText};
+}
+* { box-sizing: border-box; }
+html, body {
+  margin: 0;
+  padding: 0;
+  background: var(--bg);
+  color: var(--text);
+  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
+  font-size: 14px;
+  line-height: 1.45;
+}
+.main {
+  max-width: 1280px;
+  margin: 0 auto;
+  padding: 16px;
+  display: flex;
+  flex-direction: column;
+  gap: 16px;
+}
+.header {
+  position: sticky;
+  top: 0;
+  z-index: 2;
+  background: var(--bg);
+  display: flex;
+  align-items: center;
+  gap: 12px;
+  padding: 12px 0;
+  border-bottom: 1px solid var(--border);
+}
+.wordmark {
+  font-size: 14px;
+  color: var(--text-dim);
+  letter-spacing: 0;
+  text-transform: lowercase;
+}
+.build-name {
+  font-size: 20px;
+  color: var(--text);
+  flex: 1;
+  overflow: hidden;
+  text-overflow: ellipsis;
+  white-space: nowrap;
+}
+.elapsed {
+  font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
+  font-size: 14px;
+  color: var(--text-dim);
+  font-variant-numeric: tabular-nums;
+}
+.panel {
+  background: var(--panel);
+  border: 1px solid var(--border);
+  border-radius: 4px;
+}
+.cost-meter {
+  padding: 12px 16px;
+  display: flex;
+  flex-direction: column;
+  gap: 8px;
+}
+.cost-total {
+  font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
+  font-size: 20px;
+  color: var(--text);
+  font-variant-numeric: tabular-nums;
+}
+.cost-breakdown {
+  display: grid;
+  grid-template-columns: repeat(5, 1fr);
+  gap: 8px;
+  font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
+  font-size: 13px;
+  color: var(--text-dim);
+  font-variant-numeric: tabular-nums;
+}
+.cost-breakdown .cost-label {
+  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
+  font-size: 12px;
+  color: var(--text-dim);
+  text-transform: uppercase;
+  letter-spacing: 0.05em;
+}
+.phase-list {
+  display: flex;
+  flex-direction: column;
+  gap: 4px;
+}
+.phase-row {
+  display: flex;
+  align-items: center;
+  gap: 12px;
+  padding: 8px 12px;
+  background: var(--panel);
+  border: 1px solid var(--border);
+  border-radius: 4px;
+}
+.phase-row.phase-failed {
+  border-color: var(--error);
+}
+.phase-id {
+  font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
+  font-size: 13px;
+  color: var(--text-dim);
+  min-width: 80px;
+}
+.phase-slug {
+  flex: 1;
+  font-size: 14px;
+  color: var(--text);
+  overflow: hidden;
+  text-overflow: ellipsis;
+  white-space: nowrap;
+}
+.phase-elapsed {
+  font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
+  font-size: 13px;
+  color: var(--text-dim);
+  font-variant-numeric: tabular-nums;
+}
+.phase-error {
+  font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
+  font-size: 13px;
+  color: var(--text);
+  padding: 8px 12px;
+  white-space: pre-wrap;
+  word-break: break-word;
+}
+.row-flash {
+  animation: row-flash 300ms ease-out 1;
+}
+.pill {
+  display: inline-block;
+  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
+  font-size: 11px;
+  font-weight: 500;
+  text-transform: uppercase;
+  letter-spacing: 0.08em;
+  padding: 4px 8px;
+  border-radius: 4px;
+  border: 1px solid transparent;
+  background: var(--border);
+  color: var(--text-dim);
+}
+.pill-pending, .pill-skipped {
+  background: var(--border);
+  color: var(--text-dim);
+}
+.pill-running {
+  background: var(--info-fill);
+  color: var(--info-text);
+  animation: pill-pulse 1500ms ease-in-out infinite;
+}
+.pill-done {
+  background: var(--success-fill);
+  color: var(--success-text);
+}
+.pill-failed {
+  background: var(--error-fill);
+  color: var(--error-text);
+}
+.empty {
+  margin: 48px auto;
+  max-width: 480px;
+  padding: 24px;
+  background: var(--panel);
+  border: 1px solid var(--border);
+  border-radius: 4px;
+  text-align: center;
+  color: var(--text-dim);
+  font-size: 14px;
+}
+.empty .empty-url {
+  display: block;
+  margin-top: 12px;
+  font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
+  font-size: 13px;
+  color: var(--text);
+}
+.disconnect-banner {
+  position: sticky;
+  top: 0;
+  z-index: 3;
+  display: flex;
+  align-items: center;
+  gap: 8px;
+  padding: 8px 16px;
+  background: var(--warning-fill);
+  color: var(--warning-text);
+  border: 1px solid var(--border);
+  border-radius: 4px;
+  margin: 8px 16px 0;
+  font-size: 13px;
+}
+.disconnect-banner.hidden {
+  display: none;
+}
+.disconnect-banner.fading {
+  animation: banner-fade 400ms ease-out forwards;
+}
+.disconnect-dot {
+  width: 8px;
+  height: 8px;
+  border-radius: 4px;
+  background: var(--info);
+  animation: pill-pulse 1500ms ease-in-out infinite;
+}
+:focus-visible {
+  outline: 2px solid var(--info);
+  outline-offset: 2px;
+}
+button, [role="button"], a {
+  color: inherit;
+}
+.icon-btn {
+  display: inline-flex;
+  align-items: center;
+  gap: 4px;
+  background: transparent;
+  border: none;
+  padding: 4px;
+  color: var(--text-dim);
+  cursor: pointer;
+}
+.icon-btn:hover { color: var(--text); }
+@media (max-width: 1023px) {
+  .cost-breakdown { grid-template-columns: 1fr 1fr; }
+  .main { padding: 8px; }
+}
+@keyframes pill-pulse {
+  0%, 100% { opacity: 0.6; }
+  50% { opacity: 1.0; }
+}
+@keyframes row-flash {
+  from { background-color: var(--info-flash); }
+  to { background-color: var(--panel); }
+}
+@keyframes banner-fade {
+  from { opacity: 1; }
+  to { opacity: 0; }
+}
+@media (prefers-reduced-motion: reduce) {
+  .pill-running {
+    animation: none;
+    outline: 2px solid var(--info);
+    outline-offset: -2px;
+  }
+  .disconnect-dot { animation: none; background: var(--info); }
+  .row-flash { animation: none; }
+  .disconnect-banner.fading { animation: none; opacity: 0; }
+}
+`
+}
diff --git a/src/ui/dashboard/html.ts b/src/ui/dashboard/html.ts
