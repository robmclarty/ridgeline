+  it("favicon data-URI uses error-red when failed (criterion 36)", () => {
+    expect(decodeURIComponent(faviconDataUri("failed"))).toContain("#EF4444")
+  })
+
+  it("contains no external origins / CDN links / webfont references (criterion 50)", () => {
+    const html = renderHtml({ buildName: "demo", status: "running", port: 4411 })
+    // w3.org is the SVG namespace identifier (not a network request); 127.0.0.1 is the local port URL.
+    expect(html).not.toMatch(/https?:\/\/(?!127\.0\.0\.1|www\.w3\.org\/)/)
+    expect(html).not.toMatch(/fonts\.googleapis\.com/)
+    expect(html).not.toMatch(/fonts\.gstatic\.com/)
