@@ -0,0 +1,51 @@
+import { printError, printInfo } from "../ui/output"
+import { startDashboard, findMostRecentBuild } from "../ui/dashboard"
+
+export interface UiCommandOptions {
+  port?: string
+}
+
+export const runUi = async (
+  cwd: string,
+  buildName: string | undefined,
+  opts: UiCommandOptions,
+): Promise<void> => {
+  const resolvedBuildName = buildName ?? findMostRecentBuild(cwd)
+  if (!resolvedBuildName && buildName) {
+    printError(`No build directory found for "${buildName}"`)
+    process.exit(1)
+  }
+
+  let port: number | undefined
+  if (opts.port) {
+    const parsed = parseInt(opts.port, 10)
+    if (isNaN(parsed) || parsed < 1 || parsed > 65535) {
+      printError(`Invalid --port value: ${opts.port}`)
+      process.exit(1)
+    }
+    port = parsed
+  }
+
+  const handle = await startDashboard({
+    cwd,
+    buildName: resolvedBuildName ?? null,
+    port,
+  })
+
+  if (resolvedBuildName) {
+    printInfo(`Dashboard attached to "${resolvedBuildName}" at ${handle.url}`)
+  } else {
+    printInfo(`Dashboard at ${handle.url} (no build attached — run 'ridgeline <name> "intent"' in another terminal, then reload)`)
+  }
+
+  const shutdown = async (): Promise<void> => {
+    await handle.stop()
+    process.exit(0)
+  }
+  process.once("SIGINT", shutdown)
+  process.once("SIGTERM", shutdown)
+
+  await new Promise<void>(() => {
+    // keep the process alive until a signal arrives
+  })
+}
