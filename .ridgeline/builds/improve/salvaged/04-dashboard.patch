+import { describe, expect, it } from "vitest"
+import { renderHtml } from "../html"
+
+type Snapshot = Parameters<typeof renderHtml>[0]
+
+const FIXTURES: Record<string, Snapshot> = {
+  pending: { buildName: "fixture", status: "pending", port: 4411 },
+  running: { buildName: "fixture", status: "running", port: 4411 },
+  done: { buildName: "fixture", status: "done", port: 4411 },
+  failed: { buildName: "fixture", status: "failed", port: 4411 },
+  empty: { buildName: null, status: "pending", port: 4411 },
+}
+
+describe("state fixtures (criterion 52)", () => {
+  for (const [name, snap] of Object.entries(FIXTURES)) {
+    it(`renders ${name} state without throwing and emits the expected palette`, () => {
+      const html = renderHtml(snap)
+      expect(html).toContain("#0B0F14")
+      expect(html).toContain("ridgeline")
+      if (snap.buildName) {
+        expect(html).toContain(snap.buildName)
+        expect(html).toContain(snap.status.toUpperCase())
+      } else {
+        expect(html).toContain("No build attached.")
+      }
+    })
+  }
+
+  it("renders consistent HTML length across non-empty states", () => {
+    const lens = new Set<number>()
+    for (const key of ["pending", "running", "done", "failed"] as const) {
+      lens.add(renderHtml(FIXTURES[key]).length)
+    }
+    // Non-empty state HTML size varies by status token length (3–7 chars) but is deterministic
+    expect(lens.size).toBeGreaterThanOrEqual(1)
+  })
+})
