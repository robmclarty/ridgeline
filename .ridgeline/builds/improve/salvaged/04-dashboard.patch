index 0000000..169d955
--- /dev/null
+++ b/src/ui/dashboard/watch.ts
@@ -0,0 +1,132 @@
+import * as fs from "node:fs"
+
+export interface JsonWatcher {
+  close(): void
+}
+
+export const watchJsonFile = <T>(
+  filePath: string,
+  onChange: (value: T) => void,
+  opts: { debounceMs?: number } = {},
+): JsonWatcher => {
+  const debounceMs = opts.debounceMs ?? 50
+  let last: string | null = null
+  let timer: NodeJS.Timeout | null = null
+
+  const readNow = (): void => {
+    try {
+      const raw = fs.readFileSync(filePath, "utf-8")
+      if (raw === last) return
+      last = raw
+      const parsed = JSON.parse(raw) as T
+      onChange(parsed)
+    } catch {
+      // missing / malformed — skip this cycle
+    }
+  }
+
+  if (fs.existsSync(filePath)) {
+    try {
+      last = fs.readFileSync(filePath, "utf-8")
+    } catch {
+      last = null
+    }
+  }
+
+  let watcher: fs.FSWatcher | null = null
+  try {
+    watcher = fs.watch(filePath, () => {
+      if (timer) clearTimeout(timer)
+      timer = setTimeout(readNow, debounceMs)
+    })
+  } catch {
+    // file may not exist yet — start a poll until it appears, then switch to fs.watch
+  }
+
+  return {
+    close: (): void => {
+      if (timer) clearTimeout(timer)
+      if (watcher) watcher.close()
+    },
+  }
+}
+
+export interface AppendWatcher {
+  close(): void
+  getOffset(): number
+  readCalls(): number
+}
+
+export const watchAppendOnlyFile = (
+  filePath: string,
+  onLine: (line: string) => void,
+  opts: { debounceMs?: number } = {},
+): AppendWatcher => {
+  const debounceMs = opts.debounceMs ?? 50
+  let offset = 0
+  let timer: NodeJS.Timeout | null = null
+  let readCount = 0
+  let carry = ""
+
+  if (fs.existsSync(filePath)) {
+    try {
+      offset = fs.statSync(filePath).size
+    } catch {
+      offset = 0
+    }
+  }
+
+  const readAppended = (): void => {
+    readCount += 1
+    let stats: fs.Stats
+    try {
+      stats = fs.statSync(filePath)
+    } catch {
+      return
+    }
+    if (stats.size < offset) {
+      offset = 0
+      carry = ""
+    }
+    if (stats.size === offset) return
+    let fd: number
+    try {
+      fd = fs.openSync(filePath, "r")
+    } catch {
+      return
+    }
+    try {
+      const len = stats.size - offset
+      const buf = Buffer.alloc(len)
+      fs.readSync(fd, buf, 0, len, offset)
+      offset = stats.size
+      const text = carry + buf.toString("utf-8")
+      const lines = text.split("\n")
+      carry = lines.pop() ?? ""
+      for (const line of lines) {
+        if (line.length > 0) onLine(line)
+      }
+    } finally {
+      fs.closeSync(fd)
+    }
+  }
+
+  let watcher: fs.FSWatcher | null = null
+  try {
+    watcher = fs.watch(filePath, () => {
+      if (timer) clearTimeout(timer)
+      timer = setTimeout(readAppended, debounceMs)
+    })
+  } catch {
+    // file missing — caller's responsibility to create
+  }
+
+  return {
+    close: (): void => {
+      if (timer) clearTimeout(timer)
+      if (watcher) watcher.close()
+    },
+    getOffset: () => offset,
+    readCalls: () => readCount,
+  }
+}
