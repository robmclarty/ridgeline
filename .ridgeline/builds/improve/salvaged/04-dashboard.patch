@@ -0,0 +1,123 @@
+import * as http from "node:http"
+import * as fs from "node:fs"
+import * as path from "node:path"
+import { afterEach, beforeEach, describe, expect, it } from "vitest"
+import { makeTempDir, trackTempDir } from "../../../../test/setup"
+import { startDashboard, DashboardHandle } from "../server"
+
+const setupBuild = (cwd: string, name: string): string => {
+  const buildDir = path.join(cwd, ".ridgeline", "builds", name)
+  fs.mkdirSync(path.join(buildDir, "phases"), { recursive: true })
+  fs.writeFileSync(path.join(buildDir, "state.json"), JSON.stringify({
+    buildName: name,
+    startedAt: new Date().toISOString(),
+    pipeline: { shape: "pending", design: "skipped", spec: "pending", research: "skipped", refine: "skipped", plan: "pending", build: "pending" },
+    phases: [],
+  }))
+  fs.writeFileSync(path.join(buildDir, "budget.json"), JSON.stringify({ entries: [], totalCostUsd: 0 }))
+  fs.writeFileSync(path.join(buildDir, "trajectory.jsonl"), "")
+  return buildDir
+}
+
+interface ParsedEvent {
+  id: number | null
+  event: string | null
+  data: string
+}
+
+const parseSseChunks = (buf: string): ParsedEvent[] => {
+  const events: ParsedEvent[] = []
+  const blocks = buf.split("\n\n")
+  for (const block of blocks) {
+    if (!block.trim() || block.startsWith(":")) continue
+    let id: number | null = null
+    let event: string | null = null
+    const dataLines: string[] = []
+    for (const line of block.split("\n")) {
+      if (line.startsWith("id:")) id = parseInt(line.slice(3).trim(), 10)
+      else if (line.startsWith("event:")) event = line.slice(6).trim()
+      else if (line.startsWith("data:")) dataLines.push(line.slice(5).trim())
+    }
+    if (event) events.push({ id, event, data: dataLines.join("\n") })
+  }
+  return events
+}
+
+const collectSse = (url: string, headers: http.OutgoingHttpHeaders, timeoutMs: number): Promise<string> =>
+  new Promise((resolve, reject) => {
+    const req = http.get(url, { headers }, (res) => {
+      let buf = ""
+      res.setEncoding("utf-8")
+      res.on("data", (chunk) => {
+        buf += chunk
+      })
+      res.on("end", () => resolve(buf))
+      res.on("error", reject)
+    })
+    req.on("error", reject)
+    setTimeout(() => { req.destroy(); resolve("") }, timeoutMs)
+  })
+
+describe("SSE replay", () => {
+  let handle: DashboardHandle | null = null
+  let cwd: string
+
+  beforeEach(() => {
+    cwd = trackTempDir(makeTempDir())
+  })
+
+  afterEach(async () => {
+    if (handle) { await handle.stop(); handle = null }
+  })
+
+  it("replays events with id > Last-Event-ID on reconnect (criterion 14, 56)", async () => {
+    setupBuild(cwd, "demo")
+    handle = await startDashboard({ cwd, buildName: "demo", port: 0 })
+
+    handle.dispatch("state", { tick: 1 })
+    handle.dispatch("trajectory", JSON.stringify({ type: "phase_advance", summary: "x" }))
+    handle.dispatch("state", { tick: 2 })
+
+    const buf = await collectSse(`${handle.url}events`, { "Last-Event-ID": "1" }, 400)
+    const events = parseSseChunks(buf)
+
+    const ids = events.map((e) => e.id).filter((id): id is number => id !== null)
+    for (const id of ids) expect(id).toBeGreaterThan(1)
+    expect(events.length).toBeGreaterThanOrEqual(2)
+
+    const names = events.map((e) => e.event)
+    expect(names).toContain("state")
+    expect(names).toContain("trajectory")
+  })
+
+  it("only emits the three named event types (criterion 10)", async () => {
+    setupBuild(cwd, "demo")
+    handle = await startDashboard({ cwd, buildName: "demo", port: 0 })
+
+    handle.dispatch("state", { a: 1 })
+    handle.dispatch("budget", { entries: [], totalCostUsd: 0 })
+    handle.dispatch("trajectory", "{\"type\":\"x\"}")
+
+    const buf = await collectSse(`${handle.url}events`, { "Last-Event-ID": "0" }, 400)
+    const events = parseSseChunks(buf)
+    const allowed = new Set(["state", "budget", "trajectory"])
+    for (const e of events) {
+      expect(allowed.has(e.event!), `event name "${e.event}" should be one of state/budget/trajectory`).toBe(true)
+    }
+  })
+
+  it("monotonically increasing ids (criterion 11)", async () => {
+    setupBuild(cwd, "demo")
+    handle = await startDashboard({ cwd, buildName: "demo", port: 0 })
+    handle.dispatch("state", { a: 1 })
+    handle.dispatch("state", { a: 2 })
+    handle.dispatch("state", { a: 3 })
+
+    const buf = await collectSse(`${handle.url}events`, { "Last-Event-ID": "0" }, 400)
+    const events = parseSseChunks(buf)
+    const ids = events.map((e) => e.id).filter((id): id is number => id !== null)
+    for (let i = 1; i < ids.length; i++) {
+      expect(ids[i]).toBeGreaterThan(ids[i - 1])
+    }
+  })
+})
