+import * as http from "node:http"
+import * as fs from "node:fs"
+import * as path from "node:path"
+import { renderHtml } from "./html"
+import { watchJsonFile, watchAppendOnlyFile, AppendWatcher, JsonWatcher } from "./watch"
+
+const DEFAULT_PORT = 4411
+const HEARTBEAT_MS = 20000
+const EVENT_BUFFER_SIZE = 200
+const SSE_RETRY_MS = 2000
+const HOST = "127.0.0.1"
+
+export type SseEventName = "state" | "budget" | "trajectory"
+
+interface StoredEvent {
+  id: number
+  event: SseEventName
+  data: string
+}
+
+interface SseClient {
+  id: number
+  res: http.ServerResponse
+  heartbeat: NodeJS.Timeout
+}
+
+export interface StartDashboardOpts {
+  cwd: string
+  buildName?: string | null
+  port?: number
+}
+
+export interface DashboardHandle {
+  port: number
+  url: string
+  buildName: string | null
+  buildDir: string | null
+  server: http.Server
+  stop(): Promise<void>
+  dispatch(event: SseEventName, data: unknown): void
+}
+
+export const findMostRecentBuild = (cwd: string): string | null => {
+  const buildsDir = path.join(cwd, ".ridgeline", "builds")
+  if (!fs.existsSync(buildsDir)) return null
+  let entries: fs.Dirent[]
+  try {
+    entries = fs.readdirSync(buildsDir, { withFileTypes: true })
+  } catch {
+    return null
+  }
+  const dirs = entries.filter((e) => e.isDirectory())
+  if (dirs.length === 0) return null
+  let best: { name: string; mtime: number } | null = null
+  for (const d of dirs) {
+    try {
+      const s = fs.statSync(path.join(buildsDir, d.name))
+      if (!best || s.mtimeMs > best.mtime) best = { name: d.name, mtime: s.mtimeMs }
+    } catch {
+      // skip unreadable
+    }
+  }
+  return best ? best.name : null
+}
+
+const listenOnFreePort = (server: http.Server, startPort: number): Promise<number> => {
+  return new Promise((resolve, reject) => {
+    let attempt = startPort
+    const maxAttempts = 50
+    let tries = 0
+    const tryListen = (): void => {
+      tries += 1
+      const onError = (err: NodeJS.ErrnoException): void => {
+        if (err.code === "EADDRINUSE" && tries < maxAttempts) {
+          server.removeListener("error", onError)
+          attempt += 1
+          tryListen()
+          return
+        }
+        reject(err)
+      }
+      server.once("error", onError)
+      server.listen(attempt, HOST, () => {
+        server.removeListener("error", onError)
+        resolve(attempt)
+      })
+    }
+    tryListen()
+  })
+}
+
+export const startDashboard = async (opts: StartDashboardOpts): Promise<DashboardHandle> => {
+  const cwd = opts.cwd
+  const buildsDir = path.join(cwd, ".ridgeline", "builds")
+  const buildName = opts.buildName ?? findMostRecentBuild(cwd)
+  const buildDir = buildName ? path.join(buildsDir, buildName) : null
+
+  let nextId = 1
+  const eventBuffers: Record<SseEventName, StoredEvent[]> = {
+    state: [],
+    budget: [],
+    trajectory: [],
+  }
+  const clients = new Set<SseClient>()
+  let clientCounter = 0
+
+  const snapshot: { state: unknown; budget: unknown } = { state: null, budget: null }
+
+  const pushEvent = (event: SseEventName, data: string): StoredEvent => {
+    const stored: StoredEvent = { id: nextId++, event, data }
+    const buf = eventBuffers[event]
+    buf.push(stored)
+    if (buf.length > EVENT_BUFFER_SIZE) buf.shift()
+    return stored
+  }
+
+  const writeSse = (res: http.ServerResponse, ev: StoredEvent): void => {
+    res.write(`id: ${ev.id}\n`)
+    res.write(`event: ${ev.event}\n`)
+    res.write(`data: ${ev.data}\n\n`)
+  }
+
+  const broadcast = (ev: StoredEvent): void => {
+    for (const c of clients) {
+      try {
+        writeSse(c.res, ev)
+      } catch {
+        // client will be cleaned up on "close"
+      }
+    }
+  }
+
+  const dispatch = (event: SseEventName, data: unknown): void => {
+    const serialized = typeof data === "string" ? data : JSON.stringify(data)
+    const ev = pushEvent(event, serialized)
+    broadcast(ev)
+  }
+
+  const initialSnapshot = (): void => {
+    if (!buildDir) return
+    const statePath = path.join(buildDir, "state.json")
+    const budgetPath = path.join(buildDir, "budget.json")
+    try {
+      if (fs.existsSync(statePath)) snapshot.state = JSON.parse(fs.readFileSync(statePath, "utf-8"))
+    } catch {
+      snapshot.state = null
+    }
+    try {
+      if (fs.existsSync(budgetPath)) snapshot.budget = JSON.parse(fs.readFileSync(budgetPath, "utf-8"))
+    } catch {
+      snapshot.budget = null
+    }
+  }
+
+  initialSnapshot()
+
+  const watchers: Array<JsonWatcher | AppendWatcher> = []
+  if (buildDir) {
+    watchers.push(
+      watchJsonFile<unknown>(path.join(buildDir, "state.json"), (value) => {
+        snapshot.state = value
+        dispatch("state", value)
+      }),
+    )
+    watchers.push(
+      watchJsonFile<unknown>(path.join(buildDir, "budget.json"), (value) => {
+        snapshot.budget = value
+        dispatch("budget", value)
+      }),
+    )
+    watchers.push(
+      watchAppendOnlyFile(path.join(buildDir, "trajectory.jsonl"), (line) => {
+        dispatch("trajectory", line)
+      }),
+    )
+  }
+
+  const handleRoot = (_req: http.IncomingMessage, res: http.ServerResponse, port: number): void => {
+    const stateObj = snapshot.state as { pipeline?: { build?: string }; phases?: Array<{ status: string }> } | null
+    let status = "pending"
+    if (stateObj) {
+      if (stateObj.pipeline?.build === "running") status = "running"
+      else if (stateObj.pipeline?.build === "complete") status = "done"
+      if (stateObj.phases?.some((p) => p.status === "failed")) status = "failed"
+    }
+    const html = renderHtml({ buildName, status, port })
+    res.writeHead(200, {
+      "Content-Type": "text/html; charset=utf-8",
+      "Cache-Control": "no-cache, no-transform",
+    })
+    res.end(html)
+  }
+
+  const handleState = (_req: http.IncomingMessage, res: http.ServerResponse): void => {
+    res.writeHead(200, {
+      "Content-Type": "application/json; charset=utf-8",
+      "Cache-Control": "no-cache, no-transform",
+    })
+    res.end(JSON.stringify({
+      buildName,
+      state: snapshot.state,
+      budget: snapshot.budget,
+    }))
+  }
+
+  const handleEvents = (req: http.IncomingMessage, res: http.ServerResponse): void => {
+    res.writeHead(200, {
+      "Content-Type": "text/event-stream",
+      "Cache-Control": "no-cache, no-transform",
+      Connection: "keep-alive",
+      "X-Accel-Buffering": "no",
+    })
+    res.write(`retry: ${SSE_RETRY_MS}\n\n`)
+
+    const lastEventIdHeader = req.headers["last-event-id"]
+    const lastEventId = typeof lastEventIdHeader === "string" ? parseInt(lastEventIdHeader, 10) : NaN
+    if (!isNaN(lastEventId)) {
+      const replay: StoredEvent[] = []
+      for (const name of Object.keys(eventBuffers) as SseEventName[]) {
+        for (const ev of eventBuffers[name]) {
+          if (ev.id > lastEventId) replay.push(ev)
+        }
+      }
+      replay.sort((a, b) => a.id - b.id)
+      for (const ev of replay) writeSse(res, ev)
+    } else {
+      if (snapshot.state) {
+        const ev = pushEvent("state", JSON.stringify(snapshot.state))
+        writeSse(res, ev)
+      }
+      if (snapshot.budget) {
+        const ev = pushEvent("budget", JSON.stringify(snapshot.budget))
+        writeSse(res, ev)
+      }
+    }
+
+    const heartbeat = setInterval(() => {
+      try {
+        res.write(`: heartbeat\n\n`)
+      } catch {
+        // ignored — close handler will clean up
+      }
+    }, HEARTBEAT_MS)
+
+    const client: SseClient = { id: ++clientCounter, res, heartbeat }
+    clients.add(client)
+
+    const cleanup = (): void => {
+      clearInterval(heartbeat)
+      clients.delete(client)
+    }
+    req.on("close", cleanup)
+    res.on("close", cleanup)
+  }
+
+  const server = http.createServer((req, res) => {
+    const urlPath = (req.url ?? "/").split("?")[0]
+    if (req.method !== "GET") {
+      res.writeHead(405, { "Content-Type": "text/plain" })
+      res.end("method not allowed")
+      return
+    }
+    if (urlPath === "/" || urlPath === "/index.html") {
+      handleRoot(req, res, port)
+      return
+    }
+    if (urlPath === "/state") {
+      handleState(req, res)
+      return
+    }
+    if (urlPath === "/events") {
+      handleEvents(req, res)
+      return
+    }
+    res.writeHead(404, { "Content-Type": "text/plain" })
+    res.end("not found")
+  })
+
+  const startPort = opts.port ?? DEFAULT_PORT
+  const port = await listenOnFreePort(server, startPort)
+  const url = `http://${HOST}:${port}/`
+
+  const stop = async (): Promise<void> => {
+    for (const w of watchers) w.close()
+    for (const c of clients) {
+      clearInterval(c.heartbeat)
+      try {
+        c.res.end()
+      } catch {
+        // ignore
+      }
+    }
+    clients.clear()
+    await new Promise<void>((resolve) => {
+      server.close(() => resolve())
+      setTimeout(() => resolve(), 2000)
+    })
+  }
+
+  return { port, url, buildName, buildDir, server, stop, dispatch }
+}
