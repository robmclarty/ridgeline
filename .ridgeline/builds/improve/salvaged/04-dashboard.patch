+import * as fs from "node:fs"
+import * as path from "node:path"
+import { afterEach, beforeEach, describe, expect, it, vi } from "vitest"
+import { makeTempDir, trackTempDir } from "../../../test/setup"
+import { runUi } from "../ui"
+import { startDashboard, DashboardHandle } from "../../ui/dashboard/server"
+
+const setupBuild = (cwd: string, name: string): void => {
+  const buildDir = path.join(cwd, ".ridgeline", "builds", name)
+  fs.mkdirSync(path.join(buildDir, "phases"), { recursive: true })
+  fs.writeFileSync(path.join(buildDir, "state.json"), JSON.stringify({
+    buildName: name,
+    startedAt: new Date().toISOString(),
+    pipeline: { shape: "pending", design: "skipped", spec: "pending", research: "skipped", refine: "skipped", plan: "pending", build: "pending" },
+    phases: [],
+  }))
+  fs.writeFileSync(path.join(buildDir, "budget.json"), JSON.stringify({ entries: [], totalCostUsd: 0 }))
+  fs.writeFileSync(path.join(buildDir, "trajectory.jsonl"), "")
+}
+
+describe("ridgeline ui command", () => {
+  let handle: DashboardHandle | null = null
+  let cwd: string
+
+  beforeEach(() => {
+    cwd = trackTempDir(makeTempDir())
+  })
+
+  afterEach(async () => {
+    if (handle) { await handle.stop(); handle = null }
+  })
+
+  it("preflight is NOT triggered by the ui command (criterion 4)", async () => {
+    // Static source inspection: the ui command action does not call runPreflightGuard
+    const cliSrc = fs.readFileSync(path.resolve(__dirname, "../../cli.ts"), "utf-8")
+    const uiBlockMatch = cliSrc.match(/\.command\("ui[^]*?\.action\([^]*?\}\)/)
+    expect(uiBlockMatch, "ui command block should be present in cli.ts").toBeTruthy()
+    const uiBlock = uiBlockMatch![0]
+    expect(uiBlock.includes("runPreflightGuard")).toBe(false)
+    expect(uiBlock.includes("withConfigAndPreflight")).toBe(false)
+  })
+
+  it("startDashboard binds to 127.0.0.1 and responds to a build directory (integration)", async () => {
+    setupBuild(cwd, "demo")
+    handle = await startDashboard({ cwd, buildName: "demo", port: 0 })
+    const addr = handle.server.address()
+    if (addr && typeof addr === "object") {
+      expect(addr.address).toBe("127.0.0.1")
+    }
+    expect(handle.buildName).toBe("demo")
+  })
+
+  it("resolves the most recent build when none is specified", async () => {
+    setupBuild(cwd, "old")
+    setupBuild(cwd, "new")
+    const now = Date.now()
+    fs.utimesSync(path.join(cwd, ".ridgeline", "builds", "old"), new Date(now - 5000), new Date(now - 5000))
+    fs.utimesSync(path.join(cwd, ".ridgeline", "builds", "new"), new Date(now), new Date(now))
+    handle = await startDashboard({ cwd, buildName: null, port: 0 })
+    expect(handle.buildName).toBe("new")
+  })
+
+  it("starts with buildName null when no builds dir exists (empty state)", async () => {
+    handle = await startDashboard({ cwd, buildName: null, port: 0 })
+    expect(handle.buildName).toBeNull()
+  })
+})
+
+// vi is re-exported to satisfy lint / snapshot tooling
+void vi
+// runUi import is referenced to ensure module compiles under strict export checks
+void runUi
