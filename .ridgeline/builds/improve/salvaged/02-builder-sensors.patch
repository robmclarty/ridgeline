@@ -0,0 +1,93 @@
+import { execFileSync } from "node:child_process"
+import * as fs from "node:fs"
+import type { SensorAdapter, SensorFinding, ResolveFn } from "./index"
+import { PLAYWRIGHT_INSTALL_HINT, canResolvePlaywright } from "./index"
+
+export interface VisionSensorInput {
+  cwd: string
+  buildDir: string
+  screenshotPath: string
+  prompt?: string
+  model?: string
+  timeoutMs?: number
+}
+
+export type InvokeVisionFn = (
+  imagePath: string,
+  prompt: string,
+  model: string,
+  timeoutMs: number,
+) => string
+
+const defaultInvokeVision: InvokeVisionFn = (imagePath, prompt, model, timeoutMs) => {
+  const output = execFileSync(
+    "claude",
+    ["-p", "--model", model, "--output-format", "json", prompt, "--file", imagePath],
+    { timeout: timeoutMs, encoding: "utf-8", stdio: ["pipe", "pipe", "pipe"] },
+  )
+  const parsed = JSON.parse(output) as { result?: unknown }
+  const text = parsed.result ?? parsed
+  return typeof text === "string" ? text : JSON.stringify(text)
+}
+
+export interface VisionSensorDeps {
+  resolve?: ResolveFn
+  invokeVision?: InvokeVisionFn
+}
+
+const DEFAULT_PROMPT =
+  "Describe this screenshot of a web UI. Focus on layout issues, visual regressions, " +
+  "contrast problems, and any rendering glitches. Respond with 1-3 sentences."
+
+export const createVisionSensor = (
+  deps: VisionSensorDeps = {},
+): SensorAdapter<VisionSensorInput> => {
+  const resolveFn = deps.resolve
+  const invokeVision = deps.invokeVision ?? defaultInvokeVision
+
+  return {
+    name: "vision",
+    async run(input: VisionSensorInput): Promise<SensorFinding[]> {
+      if (!canResolvePlaywright(resolveFn)) {
+        return [{
+          kind: "vision",
+          summary: `playwright not resolvable; install with: ${PLAYWRIGHT_INSTALL_HINT}`,
+          severity: "warning",
+        }]
+      }
+
+      if (!fs.existsSync(input.screenshotPath)) {
+        return [{
+          kind: "vision",
+          summary: `screenshot not found at ${input.screenshotPath}`,
+          severity: "warning",
+        }]
+      }
+
+      const prompt = input.prompt ?? DEFAULT_PROMPT
+      const model = input.model ?? "opus"
+      const timeoutMs = input.timeoutMs ?? 60_000
+
+      try {
+        const summary = invokeVision(input.screenshotPath, prompt, model, timeoutMs).trim()
+        return [{
+          kind: "vision",
+          path: input.screenshotPath,
+          summary: summary || "(no description)",
+          severity: "info",
+        }]
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err)
+        return [{
+          kind: "vision",
+          summary: `claude vision call failed: ${msg}`,
+          severity: "warning",
+        }]
+      }
+    },
+  }
+}
+
+export const visionSensor: SensorAdapter<VisionSensorInput> = createVisionSensor()
+
+export default visionSensor
