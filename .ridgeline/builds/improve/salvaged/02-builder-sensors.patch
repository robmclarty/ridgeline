+export type SensorRegistry = Record<SensorName, SensorAdapter<unknown>>
+
+export const getBuilderSensorRegistry = (): SensorRegistry => ({
+  playwright: playwrightSensor as SensorAdapter<unknown>,
+  vision: visionSensor as SensorAdapter<unknown>,
+  a11y: a11ySensor as SensorAdapter<unknown>,
+  contrast: contrastSensor as SensorAdapter<unknown>,
+})
+
+export interface SensorRunContext {
+  cwd: string
+  buildDir: string
+  phaseId: string
+}
+
+export interface RunBuilderSensorsOptions {
+  registry?: SensorRegistry
+  warn?: (msg: string) => void
+}
+
+const buildSensorInput = (
+  name: SensorName,
+  context: SensorRunContext,
+  lastScreenshot: string | null,
+): unknown => {
+  if (name === "playwright") {
+    return { cwd: context.cwd, buildDir: context.buildDir }
+  }
+  if (name === "a11y") {
+    return { cwd: context.cwd, buildDir: context.buildDir, url: "http://127.0.0.1:5173/" }
+  }
+  if (name === "vision") {
+    return {
+      cwd: context.cwd,
+      buildDir: context.buildDir,
+      screenshotPath: lastScreenshot ?? "",
+    }
+  }
+  // contrast
+  return { pairs: [] }
+}
+
+export const runBuilderSensors = async (
+  detection: DetectionReport,
+  context: SensorRunContext,
+  opts: RunBuilderSensorsOptions = {},
+): Promise<SensorFinding[]> => {
+  const findings: SensorFinding[] = []
+  if (detection.suggestedSensors.length === 0) return findings
+
+  const registry = opts.registry ?? getBuilderSensorRegistry()
+  const warn = opts.warn ?? ((msg: string) => printWarn(msg))
+
+  let lastScreenshot: string | null = null
+  for (const name of detection.suggestedSensors) {
+    const sensor = registry[name]
+    if (!sensor) continue
+    const input = buildSensorInput(name, context, lastScreenshot)
+    try {
+      const results = await sensor.run(input)
+      for (const r of results) {
+        findings.push(r)
+        if (r.kind === "screenshot" && r.path) lastScreenshot = r.path
+      }
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err)
+      warn(`sensor ${name} failed: ${msg}`)
+    }
+  }
+  return findings
+}
+
+export const writeSensorFindings = (
+  buildDir: string,
+  phaseId: string,
+  findings: SensorFinding[],
+): string => {
