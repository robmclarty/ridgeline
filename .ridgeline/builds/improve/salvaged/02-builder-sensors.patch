@@ -0,0 +1,77 @@
+import { hex as wcagHex } from "wcag-contrast"
+import type { SensorAdapter, SensorFinding } from "./index"
+
+export interface HexPair {
+  label: string
+  foreground: string
+  background: string
+  largeText?: boolean
+}
+
+export interface ContrastSensorInput {
+  pairs: HexPair[]
+}
+
+export type ContrastFn = (fg: string, bg: string) => number
+
+export interface ContrastSensorDeps {
+  contrast?: ContrastFn
+}
+
+const AA_NORMAL = 4.5
+const AA_LARGE = 3.0
+
+export const createContrastSensor = (
+  deps: ContrastSensorDeps = {},
+): SensorAdapter<ContrastSensorInput> => {
+  const contrast = deps.contrast ?? ((fg: string, bg: string): number => wcagHex(fg, bg))
+
+  return {
+    name: "contrast",
+    async run(input: ContrastSensorInput): Promise<SensorFinding[]> {
+      if (input.pairs.length === 0) {
+        return [{
+          kind: "contrast",
+          summary: "no color pairs provided",
+          severity: "info",
+        }]
+      }
+
+      const findings: SensorFinding[] = []
+      for (const pair of input.pairs) {
+        let ratio: number
+        try {
+          ratio = contrast(pair.foreground, pair.background)
+        } catch (err) {
+          const msg = err instanceof Error ? err.message : String(err)
+          findings.push({
+            kind: "contrast",
+            summary: `${pair.label}: failed to compute (${msg})`,
+            severity: "warning",
+          })
+          continue
+        }
+        const threshold = pair.largeText ? AA_LARGE : AA_NORMAL
+        const rounded = Math.round(ratio * 100) / 100
+        if (ratio < threshold) {
+          findings.push({
+            kind: "contrast",
+            summary: `${pair.label}: ${pair.foreground} on ${pair.background} = ${rounded}:1 (below WCAG AA ${threshold}:1)`,
+            severity: "error",
+          })
+        } else {
+          findings.push({
+            kind: "contrast",
+            summary: `${pair.label}: ${pair.foreground} on ${pair.background} = ${rounded}:1`,
+            severity: "info",
+          })
+        }
+      }
+      return findings
+    },
+  }
+}
+
+export const contrastSensor: SensorAdapter<ContrastSensorInput> = createContrastSensor()
+
+export default contrastSensor
