+export interface SensorFinding {
+  kind: "screenshot" | "a11y" | "contrast" | "vision"
+  path?: string
+  summary: string
+  severity: "info" | "warning" | "error"
+}
+
+export interface SensorAdapter<Input = unknown> {
+  name: string
+  run(input: Input): Promise<SensorFinding[]>
+}
+
+export const PLAYWRIGHT_INSTALL_HINT =
+  "npm install --save-dev playwright && npx playwright install chromium"
+
+export type ResolveFn = (id: string) => string
+
+export const canResolvePlaywright = (
+  resolveFn: ResolveFn = (id) => require.resolve(id),
+): boolean => {
+  try {
+    resolveFn("playwright")
+    return true
+  } catch {
+    return false
+  }
+}
+
+export const isSandboxed = (env: NodeJS.ProcessEnv = process.env): boolean =>
+  Boolean(
+    env.GREYWALL ||
+      env.GREYWALL_ACTIVE ||
+      env.GREYWALL_SESSION ||
+      env.BWRAP_DETECTED ||
+      env.BWRAP_ACTIVE ||
+      env.RIDGELINE_SANDBOX,
+  )
+
+export { playwrightSensor, createPlaywrightSensor } from "./playwright"
+export type { PlaywrightSensorInput, PlaywrightSensorDeps, HttpProbeFn } from "./playwright"
+export { a11ySensor, createA11ySensor } from "./a11y"
+export type { A11ySensorInput, A11ySensorDeps } from "./a11y"
+export { visionSensor, createVisionSensor } from "./vision"
+export type { VisionSensorInput, VisionSensorDeps } from "./vision"
+export { contrastSensor, createContrastSensor } from "./contrast"
+export type { ContrastSensorInput, ContrastSensorDeps, HexPair } from "./contrast"
diff --git a/src/sensors/playwright.ts b/src/sensors/playwright.ts
new file mode 100644
index 0000000..755c989
--- /dev/null
+++ b/src/sensors/playwright.ts
@@ -0,0 +1,247 @@
+import * as fs from "node:fs"
+import * as http from "node:http"
+import * as path from "node:path"
+import type { SensorAdapter, SensorFinding, ResolveFn } from "./index"
+import { PLAYWRIGHT_INSTALL_HINT, canResolvePlaywright, isSandboxed } from "./index"
+
+export const PROBE_PORTS: readonly number[] = [5173, 3000, 8080, 4321]
+export const PROBE_TIMEOUT_MS = 250
+export const PROBE_OVERALL_CAP_MS = 1000
+export const LAUNCH_TIMEOUT_MS = 10_000
+
+export interface PlaywrightSensorInput {
+  cwd: string
+  buildDir: string
+  shapeMdPath?: string
+  outputDir?: string
+  url?: string
+}
+
+export interface ParsedPort {
+  port: number | null
+  parseError: string | null
+}
+
+export const PORT_LINE_RE = /^\s*-\s*\*\*Dev server port:\*\*\s+(\d+)\s*$/m
+
+export const parsePortFromShape = (content: string): ParsedPort => {
+  const headingRe = /^##\s+Runtime\s*$/gm
+  const headingStarts: number[] = []
+  let match: RegExpExecArray | null
+  while ((match = headingRe.exec(content)) !== null) {
+    headingStarts.push(match.index)
+  }
+  if (headingStarts.length === 0) return { port: null, parseError: null }
+  if (headingStarts.length > 1) {
+    return { port: null, parseError: "multiple ## Runtime sections" }
+  }
+  const afterHeading = content.slice(headingStarts[0])
+  const nextHeadingOffset = afterHeading.slice(1).search(/^##\s/m)
+  const runtimeBlock = nextHeadingOffset >= 0
+    ? afterHeading.slice(0, nextHeadingOffset + 1)
+    : afterHeading
+  const portMatch = runtimeBlock.match(PORT_LINE_RE)
+  if (!portMatch) return { port: null, parseError: null }
+  const raw = portMatch[1]
+  const port = Number(raw)
+  if (!Number.isInteger(port) || port < 1 || port > 65535) {
+    return { port: null, parseError: `port out of range [1, 65535]: ${raw}` }
+  }
+  return { port, parseError: null }
+}
+
+export type HttpProbeFn = (url: string, timeoutMs: number) => Promise<boolean>
+
+const defaultHttpProbe: HttpProbeFn = (url, timeoutMs) =>
+  new Promise((resolve) => {
+    let settled = false
+    const done = (ok: boolean): void => {
+      if (settled) return
+      settled = true
+      clearTimeout(timer)
+      resolve(ok)
+    }
+    const timer = setTimeout(() => {
+      req.destroy()
+      done(false)
+    }, timeoutMs)
+    const req = http.request(url, { method: "HEAD", timeout: timeoutMs }, (res) => {
+      res.resume()
+      done(typeof res.statusCode === "number")
+    })
+    req.on("error", () => done(false))
+    req.end()
+  })
+
+export interface ProbeResult {
+  port: number | null
+  callOrder: number[]
+}
+
+export const probeDevServerPorts = async (
+  ports: readonly number[] = PROBE_PORTS,
+  probe: HttpProbeFn = defaultHttpProbe,
+  overallCapMs: number = PROBE_OVERALL_CAP_MS,
+  now: () => number = Date.now,
+): Promise<ProbeResult> => {
+  const start = now()
+  const callOrder: number[] = []
+  for (const p of ports) {
+    if (now() - start >= overallCapMs) break
+    callOrder.push(p)
+    const remaining = overallCapMs - (now() - start)
+    const ok = await probe(`http://127.0.0.1:${p}/`, Math.min(PROBE_TIMEOUT_MS, remaining))
+    if (ok) return { port: p, callOrder }
+  }
+  return { port: null, callOrder }
+}
+
+export interface LaunchResult {
+  screenshotPath: string
+}
+
+export type LaunchFn = (
+  url: string,
+  args: string[],
+  outputDir: string,
+  timeoutMs: number,
+) => Promise<LaunchResult>
+
+interface PlaywrightLike {
+  chromium: {
+    launch(opts: { args: string[]; timeout: number }): Promise<PlaywrightBrowser>
+  }
+}
+
+interface PlaywrightBrowser {
+  newPage(): Promise<PlaywrightPage>
+  close(): Promise<void>
+}
+
+interface PlaywrightPage {
+  goto(url: string, opts: { waitUntil: string; timeout: number }): Promise<unknown>
+  screenshot(opts: { path: string; fullPage: boolean }): Promise<unknown>
+  addScriptTag(opts: { path: string }): Promise<unknown>
+  evaluate<T>(fn: () => T | Promise<T>): Promise<T>
+}
+
+const defaultLaunch: LaunchFn = async (url, args, outputDir, timeoutMs) => {
+  // eslint-disable-next-line @typescript-eslint/no-require-imports
+  const playwright = require("playwright") as PlaywrightLike
+  const browser = await playwright.chromium.launch({ args, timeout: timeoutMs })
+  try {
+    const page = await browser.newPage()
+    await page.goto(url, { waitUntil: "load", timeout: timeoutMs })
+    fs.mkdirSync(outputDir, { recursive: true })
+    const shotPath = path.join(outputDir, `playwright-${Date.now()}.png`)
+    await page.screenshot({ path: shotPath, fullPage: true })
+    return { screenshotPath: shotPath }
+  } finally {
+    await browser.close()
+  }
+}
+
+const withTimeout = async <T>(p: Promise<T>, ms: number, label: string): Promise<T> =>
+  Promise.race<T>([
+    p,
+    new Promise<T>((_, reject) =>
+      setTimeout(() => reject(new Error(`${label} timeout after ${ms}ms`)), ms),
+    ),
+  ])
+
+export interface PlaywrightSensorDeps {
+  resolve?: ResolveFn
+  probe?: HttpProbeFn
+  launch?: LaunchFn
+  sandboxed?: () => boolean
+  warn?: (msg: string) => void
+}
+
+const installHintFinding = (reason: string): SensorFinding => ({
+  kind: "screenshot",
+  summary: `${reason}; install with: ${PLAYWRIGHT_INSTALL_HINT}`,
+  severity: "warning",
+})
+
+export const createPlaywrightSensor = (
+  deps: PlaywrightSensorDeps = {},
+): SensorAdapter<PlaywrightSensorInput> => {
+  const resolveFn = deps.resolve
+  const probe = deps.probe
+  const launch = deps.launch ?? defaultLaunch
+  const sandboxed = deps.sandboxed ?? isSandboxed
+  const warn = deps.warn ?? ((msg: string) => {
+    process.stderr.write(`[ridgeline] WARN: ${msg}\n`)
+  })
+
+  return {
+    name: "playwright",
+    async run(input: PlaywrightSensorInput): Promise<SensorFinding[]> {
+      if (!canResolvePlaywright(resolveFn)) {
+        return [installHintFinding("playwright not resolvable")]
+      }
+
+      let url = input.url ?? null
+      if (!url) {
+        let port: number | null = null
+        const shapePath = input.shapeMdPath ?? path.join(input.buildDir, "shape.md")
+        if (fs.existsSync(shapePath)) {
+          try {
+            const content = fs.readFileSync(shapePath, "utf-8")
+            const parsed = parsePortFromShape(content)
+            if (parsed.parseError) {
+              warn(`shape.md ## Runtime ${parsed.parseError}; falling back to port probing`)
+            } else if (parsed.port !== null) {
+              port = parsed.port
+            }
+          } catch {
+            // fall through to probing
+          }
+        }
+        if (port === null) {
+          const probed = await probeDevServerPorts(PROBE_PORTS, probe)
+          if (probed.port === null) {
+            return [{
+              kind: "screenshot",
+              summary: `no dev server detected on ${PROBE_PORTS.join(", ")}`,
+              severity: "warning",
+            }]
+          }
+          port = probed.port
+        }
+        url = `http://127.0.0.1:${port}/`
+      }
+
+      const args = sandboxed() ? ["--no-sandbox", "--disable-setuid-sandbox"] : []
+      const outputDir = input.outputDir ?? path.join(input.buildDir, "sensors")
+
+      try {
+        const result = await withTimeout(
+          launch(url, args, outputDir, LAUNCH_TIMEOUT_MS),
+          LAUNCH_TIMEOUT_MS,
+          "chromium launch",
+        )
+        return [{
+          kind: "screenshot",
+          path: result.screenshotPath,
+          summary: `captured ${url}`,
+          severity: "info",
+        }]
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err)
+        if (/browser\s*not\s*found|executable\s*doesn't\s*exist/i.test(msg)) {
+          return [installHintFinding(`chromium binary missing (${msg})`)]
+        }
+        return [{
+          kind: "screenshot",
+          summary: `sandbox-incompatible: chromium launch failed (${msg})`,
+          severity: "warning",
+        }]
+      }
+    },
+  }
+}
+
+export const playwrightSensor: SensorAdapter<PlaywrightSensorInput> = createPlaywrightSensor()
+
+export default playwrightSensor
