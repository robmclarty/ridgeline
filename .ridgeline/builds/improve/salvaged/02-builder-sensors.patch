diff --git a/src/sensors/a11y.ts b/src/sensors/a11y.ts
new file mode 100644
index 0000000..85279a4
--- /dev/null
+++ b/src/sensors/a11y.ts
@@ -0,0 +1,122 @@
+import type { SensorAdapter, SensorFinding, ResolveFn } from "./index"
+import { PLAYWRIGHT_INSTALL_HINT, canResolvePlaywright, isSandboxed } from "./index"
+
+const LAUNCH_TIMEOUT_MS = 10_000
+
+export interface A11ySensorInput {
+  cwd: string
+  buildDir: string
+  url: string
+}
+
+export interface AxeViolation {
+  id: string
+  impact: string | null
+  description: string
+  nodes: { target: string[] }[]
+}
+
+export interface AxeResult {
+  violations: AxeViolation[]
+}
+
+export type RunAxeFn = (url: string, args: string[], timeoutMs: number) => Promise<AxeResult>
+
+interface PlaywrightLike {
+  chromium: {
+    launch(opts: { args: string[]; timeout: number }): Promise<PlaywrightBrowser>
+  }
+}
+
+interface PlaywrightBrowser {
+  newPage(): Promise<PlaywrightPage>
+  close(): Promise<void>
+}
+
+interface PlaywrightPage {
+  goto(url: string, opts: { waitUntil: string; timeout: number }): Promise<unknown>
+  addScriptTag(opts: { path: string }): Promise<unknown>
+  evaluate<T>(fn: () => T | Promise<T>): Promise<T>
+}
+
+const defaultRunAxe: RunAxeFn = async (url, args, timeoutMs) => {
+  // eslint-disable-next-line @typescript-eslint/no-require-imports
+  const playwright = require("playwright") as PlaywrightLike
+  const axePath = require.resolve("axe-core")
+  const browser = await playwright.chromium.launch({ args, timeout: timeoutMs })
+  try {
+    const page = await browser.newPage()
+    await page.goto(url, { waitUntil: "load", timeout: timeoutMs })
+    await page.addScriptTag({ path: axePath })
+    const result = await page.evaluate<AxeResult>(() => {
+      const axe = (globalThis as unknown as { axe: { run: () => Promise<AxeResult> } }).axe
+      return axe.run()
+    })
+    return result
+  } finally {
+    await browser.close()
+  }
+}
+
+export interface A11ySensorDeps {
+  resolve?: ResolveFn
+  runAxe?: RunAxeFn
+  sandboxed?: () => boolean
+}
+
+export const createA11ySensor = (
+  deps: A11ySensorDeps = {},
+): SensorAdapter<A11ySensorInput> => {
+  const resolveFn = deps.resolve
+  const runAxe = deps.runAxe ?? defaultRunAxe
+  const sandboxed = deps.sandboxed ?? isSandboxed
+
+  return {
+    name: "a11y",
+    async run(input: A11ySensorInput): Promise<SensorFinding[]> {
+      if (!canResolvePlaywright(resolveFn)) {
+        return [{
+          kind: "a11y",
+          summary: `playwright not resolvable; install with: ${PLAYWRIGHT_INSTALL_HINT}`,
+          severity: "warning",
+        }]
+      }
+
+      const args = sandboxed() ? ["--no-sandbox", "--disable-setuid-sandbox"] : []
+
+      try {
+        const result = await runAxe(input.url, args, LAUNCH_TIMEOUT_MS)
+        if (result.violations.length === 0) {
+          return [{
+            kind: "a11y",
+            summary: `axe-core: no WCAG violations on ${input.url}`,
+            severity: "info",
+          }]
+        }
+        return result.violations.map((v): SensorFinding => ({
+          kind: "a11y",
+          summary: `${v.id} (${v.impact ?? "unknown"}): ${v.description} [${v.nodes.length} node(s)]`,
+          severity: v.impact === "critical" || v.impact === "serious" ? "error" : "warning",
+        }))
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err)
+        if (/browser\s*not\s*found|executable\s*doesn't\s*exist/i.test(msg)) {
+          return [{
+            kind: "a11y",
+            summary: `chromium binary missing (${msg}); install with: ${PLAYWRIGHT_INSTALL_HINT}`,
+            severity: "warning",
+          }]
+        }
+        return [{
+          kind: "a11y",
+          summary: `sandbox-incompatible: axe-core run failed (${msg})`,
+          severity: "warning",
+        }]
+      }
+    },
+  }
+}
+
+export const a11ySensor: SensorAdapter<A11ySensorInput> = createA11ySensor()
+
+export default a11ySensor
