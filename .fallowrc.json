{
  "entry": ["examples/**", "scripts/**"],
  "ignoreDependencies": ["colorthief", "axe-core", "wcag-contrast"],
  "ignoreExports": [
    { "file": "src/engine/claude/stream.types.ts", "exports": ["StreamEvent"] },
    { "file": "src/commands/spec.ts", "exports": ["SpecOptions"] },
    { "file": "src/commands/input.ts", "exports": ["ResolvedInput"] },
    { "file": "src/engine/discovery/plugin.scan.ts", "exports": ["PluginDir"] },
    { "file": "src/stores/phases.ts", "exports": ["PhaseContent"] },
    { "file": "src/ui/spinner.ts", "exports": ["Spinner"] },
    { "file": "src/ui/transcript.ts", "exports": ["disableTranscript"] },
    { "file": "src/catalog/colorthief.d.ts", "exports": ["default"] }
  ],
  "duplicates": {
    "ignore": [
      "**/__tests__/**",
      "src/engine/pipeline/ensemble.exec.ts",
      "src/engine/pipeline/specify.exec.ts"
    ],
    "minLines": 10
  },
  "health": {
    "maxCyclomatic": 25,
    "maxCognitive": 30
  }
}
